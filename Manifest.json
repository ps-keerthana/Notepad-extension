{
  "manifest_version": 3,
  "name": "Smart Notepad - Quick Ideas Capture",
  "version": "4.0",
  "description": "Notes with voice, sidebar, reminders, tab groups, keyboard nav, dark mode.",
  "permissions": [
    "storage",
    "tabs",
    "tabGroups",
    "contextMenus",
    "scripting",
    "sidePanel",
    "alarms",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Smart Notepad"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+N",
        "mac": "Command+Shift+N"
      },
      "description": "Open Smart Notepad sidebar"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
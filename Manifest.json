{
  "manifest_version": 3,
  "name": "Smart Notepad - Quick Ideas Capture",
  "version": "2.0",
  "description": "Notes with voice, context, hashtag filters, dark mode, pin & categories.",
  "permissions": ["storage", "tabs", "contextMenus", "scripting"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Smart Notepad"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+N",
        "mac": "Command+Shift+N"
      },
      "description": "Open Smart Notepad"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
